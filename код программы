PROGRAM PLC_PRG
VAR
	//b – это булево значение, i-integer)
bNext : BOOL;     //кнопка «дальше» (привяжем к клавише F1)
bReset : BOOL;   //кнопка «сброс» (привяжем к F2)
iState : INT;   //тек.состояние 1, 2, 3, 99 (99 - ошибка)
light1 : BOOL; //лампочка позиции 1 (будет TRUE когда будем в состоянии 1, тем самым вкл.вирт.лампу)
light2 : BOOL; //лампочка позиции 2
light3 : BOOL; //лампочка позиции 3
lightErr : BOOL; //лампочка ошибки
bNextOld : BOOL := FALSE; //прошлое значение кнопки «дальше» (для детекции нажатия), когда программа выполнялась)
bResetOld : BOOL := FALSE; //прошле значение кнопки «сброса»
END_VAR

// конечный автомат (машина состояний)
CASE iState OF //CASE смотрит на значение iState и выполняет тот блок, номер которого совпадает
//Блок состояния 1 (ждем кнопку «дальше»)
1:
    light1 := TRUE; //при входе в состояние 1 вкл. Только первую лампочку, остальные гасим. Это  гарантия того, что если мы придем из ошибки, старые лампочки не останутся гореть.
    light2 := FALSE;
    light3 := FALSE;
    lightErr := FALSE;
    IF bNext AND NOT bNextOld THEN
        iState := 2;
    END_IF //bNextOld мы обновляем в конце программы, поэтому внутри CASE она еще хранит значение с прошлого цикла. 
//Если нажатие случилось – переходим в состояние 2
//Блок состояния 2 (ждем кнопку «дальше»)
2:
    light1 := FALSE;
    light2 := TRUE;
    light3 := FALSE;
    lightErr := FALSE;
    IF bNext AND NOT bNextOld THEN
        iState := 3;
    END_IF //Все тоже самое, но горит лампа 2. При нажатии – состояние 3.
//Блок состояния 3 - ждем кнопку «дальше» (переход в ошибку)
3:
    light1 := FALSE;
    light2 := FALSE;
    light3 := TRUE;
    lightErr := FALSE;
    IF bNext AND NOT bNextOld THEN
        iState := 99;
    END_IF // горит лампа 3. При нажатии – ошибка (99).
//Блок состояния 99 (ошибка)
99:
    light1 := FALSE;
    light2 := FALSE;
    light3 := FALSE;
    lightErr := TRUE;
    IF bReset AND NOT bResetOld THEN
        iState := 1;
    END_IF 
//В ошибке горит только красная лампа. Выход – только по нажатию кнопки «сброс», а «дальше» игнорируется.
//блок ELSE (защита от мусора). На всякий случай, если iState стал неизвестным числом
ELSE
    iState := 1; //Если вдруг значение будет 0, 5, -100 – программа сама поставит состояние 1.
END_CASE //Закрываем CASE
//сохраняем тек.значения для след.цикла (то, что было bNext в этом цикле, станет bNextOld в следующем)
bNextOld := bNext;
bResetOld := bReset;
